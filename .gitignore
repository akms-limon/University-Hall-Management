# ----------------------------------------
# Dependencies
# ----------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/

# ----------------------------------------
# Build output
# ----------------------------------------
dist/
build/
frontend/dist/
backend/dist/

# ----------------------------------------
# Coverage / test artifacts
# ----------------------------------------
coverage/
backend/coverage/
frontend/coverage/
.nyc_output/

# ----------------------------------------
# Environment files (secrets)
# ----------------------------------------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ----------------------------------------
# Logs
# ----------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/.backend.dev.*
backend/.localhostrun.*
backend/.localtunnel.*

# ----------------------------------------
# Runtime / temp
# ----------------------------------------
tmp/
temp/
*.tmp
*.bak

# Local uploads/cache generated at runtime
backend/uploads/*
!backend/uploads/.gitkeep

# ----------------------------------------
# OS / editor files
# ----------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

