NODE_ENV=development
PORT=5000
TRUST_PROXY=false

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/uhas

# Auth and JWT
JWT_SECRET=replace-with-min-32-char-random-secret
JWT_EXPIRES_IN=7d

# Cookie and client
CLIENT_URL=http://localhost:5173
COOKIE_SECRET=replace-with-min-32-char-cookie-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
COOKIE_MAX_AGE_MS=604800000

# Rate limiting and login protection
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MS=1800000

# Upload placeholders (future modules)
UPLOAD_STORAGE=memory
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=university-hall-management

# Payment gateway configuration for meal ordering
# Supported now: sandbox (default), mock, internal_wallet, or a provider integrated via PAYMENT_API_BASE_URL
PAYMENT_PROVIDER=sandbox
PAYMENT_API_BASE_URL=
PAYMENT_API_KEY=
PAYMENT_API_SECRET=
PAYMENT_WEBHOOK_SECRET=

# SSLCommerz wallet-deposit integration
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true
SSLCOMMERZ_SANDBOX_BASE_URL=https://sandbox.sslcommerz.com
SSLCOMMERZ_LIVE_BASE_URL=https://securepay.sslcommerz.com
SSLCOMMERZ_SUCCESS_URL=http://localhost:5000/api/v1/wallet/deposits/sslcommerz/success
SSLCOMMERZ_FAIL_URL=http://localhost:5000/api/v1/wallet/deposits/sslcommerz/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:5000/api/v1/wallet/deposits/sslcommerz/cancel
SSLCOMMERZ_IPN_URL=http://localhost:5000/api/v1/wallet/deposits/sslcommerz/ipn
APP_TIMEZONE=Asia/Dhaka

# Bootstrap provost account
PROVOST_NAME=Initial Provost
PROVOST_EMAIL=provost@just.edu.bd
PROVOST_PHONE=01700000000
PROVOST_PASSWORD=ChangeThis123!

# Production guidance (example)
# NODE_ENV=production
# CLIENT_URL=https://app.yourdomain.com,https://admin.yourdomain.com
# COOKIE_DOMAIN=.yourdomain.com
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
# TRUST_PROXY=true
